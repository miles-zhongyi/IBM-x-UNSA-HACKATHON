# Copy this file to .env and fill in your credentials.
# The pipeline works WITHOUT these — it falls back to heuristic extraction.
# Set them only when you want to use the real IBM watsonx backend.

# IBM watsonx.ai credentials (optional — production extraction)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Embedding backend (optional)
# Set to "hashed" to force the offline fallback (useful in CI or air-gapped envs)
# EMBEDDING_BACKEND=hashed
